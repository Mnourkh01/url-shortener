SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# Base URL used to build the short links returned by the API.
APP_BASE_URL=http://localhost:8080

# These defaults match docker-compose.yml.
DB_NAME=shortener_db
DB_PORT=5432
DB_URL=jdbc:postgresql://localhost:5432/shortener_db
DB_USERNAME=shortener_user
DB_PASSWORD=shortener_pass

REDIS_HOST=localhost
REDIS_PORT=6379

# Rate limit on link creation (per client IP).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_TOKENS=20
RATE_LIMIT_REFILL_PERIOD_SECONDS=60
